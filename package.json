{
  "name": "Lepton",
  "version": "1.10.1-alpha.1",
  "description": "Democratizing Code Snippets Management (macOS/Win/Linux)",
  "productName": "Lepton",
  "main": "main.js",
  "scripts": {
    "lint": "eslint app",
    "start": "electron ./main.js",
    "build": "npm run license && npm run webpack-dev",
    "license": "license-checker-evergreen --production --relativeLicensePath --json --legacy > license.json",
    "webpack-watch": "webpack --watch",
    "webpack-dev": "webpack --mode development",
    "webpack-prod": "webpack --mode production",
    "test": "npm run test:unit && npm run test:build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:build": "webpack --mode development",
    "test:smoke": "npm run test:build && node tests/smoke/electron-render-smoke.js",
    "test:packaged-smoke": "npm run pack && node tests/smoke/electron-packaged-smoke.js",
    "package:prepare": "npm run license && npm run webpack-prod",
    "dist": "npm run package:prepare && electron-builder",
    "pack": "npm run package:prepare && electron-builder --dir",
    "release": "npm run package:prepare && electron-builder",
    "check-outdated": "check-outdated --ignore-pre-releases --ignore-dev-dependencies --ignore-packages package1,package2 --columns name,type,current,latest,changes --types major,minor,patch,reverted",
    "preversion": "npm run lint && npm run test && npm run check-outdated"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hackjutsu/Lepton.git"
  },
  "keywords": [
    "gist",
    "js",
    "electron",
    "desktop"
  ],
  "author": "CosmoX",
  "license": "MIT",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "babel-loader": "^8.4.1",
    "check-outdated": "^2.11.0",
    "css-loader": "^5.0.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^7.11.0",
    "eslint-config-standard": "^16.0.0",
    "eslint-plugin-import": "^2.14.0",
    "eslint-plugin-node": "^11.0.0",
    "eslint-plugin-promise": "^5.0.0",
    "eslint-plugin-react": "^7.11.1",
    "eslint-plugin-standard": "^5.0.0",
    "file-loader": "^6.0.0",
    "html-loader": "^2.0.0",
    "json-loader": "^0.5.7",
    "license-checker-evergreen": "^6.3.1",
    "raw-loader": "^4.0.0",
    "sass": "^1.69.7",
    "sass-loader": "^8.0.0",
    "style-loader": "^1.2.1",
    "text-loader": "0.0.1",
    "url-loader": "^4.1.0",
    "vitest": "^4.1.9",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "autolinker": "^3.14.1",
    "bluebird": "^3.5.3",
    "boring-avatars": "^1.5.8",
    "chart.js": "^1.1.1",
    "codemirror": "^5.42.0",
    "codemirror-one-dark-theme": "^1.1.1",
    "electron-context-menu": "^3.0.0",
    "electron-is-dev": "^2.0.0",
    "electron-json-storage-sync": "^1.1.1",
    "electron-localshortcut": "^3.1.0",
    "electron-updater": "^6.8.9",
    "electron-window-state": "^5.0.0",
    "fuse.js": "^3.3.0",
    "highlight.js": "^11.0.0",
    "highlightjs-graphql": "^1.0.2",
    "highlightjs-solidity": "^1.0.6",
    "human-readable-time": "^0.3.0",
    "markdown-it": "^12.0.0",
    "markdown-it-katex": "^2.0.3",
    "markdown-it-task-lists": "^2.1.1",
    "moment": "^2.22.2",
    "nconf": "^0.11.0",
    "notebookjs": "^0.6.0",
    "prismjs": "^1.15.0",
    "proxy-agent": "^4.0.0",
    "react": "^19.2.7",
    "react-bootstrap": "^0.32.4",
    "react-chartjs": "^1.2.0",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-split-pane": "^3.2.0",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "request": "^2.88.0",
    "request-promise": "^4.2.2",
    "twitter-text": "^3.0.0",
    "valid-filename": "^3.1.0",
    "winston": "^3.19.0"
  },
  "build": {
    "appId": "com.cosmox.lepton",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "7z",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "publish": [
        "github"
      ],
      "darkModeSupport": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "7z",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "publish": [
        "github"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage",
        "snap"
      ],
      "publish": [
        "github"
      ]
    }
  }
}
